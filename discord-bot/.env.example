# ================================================================
#  Bot de Placas RD — Variables de Entorno
#  Copia este archivo como .env y rellena los valores
# ================================================================

# Token del Bot de Discord (OBLIGATORIO)
# Obtén tu token en: https://discord.com/developers/applications
DISCORD_TOKEN=TU_TOKEN_AQUI

# ID del servidor (Guild) para sincronización rápida de slash commands
# Déjalo en 0 para sincronización global (puede tardar hasta 1 hora)
# Para obtener el ID: activa Modo Desarrollador en Discord → clic derecho en el servidor
GUILD_ID=0

# Nombre del rol de administrador del sistema de placas
# Los miembros con este rol pueden usar comandos /admin
ADMIN_ROLE_NAME=Gobierno

# ID del canal donde se registran los logs de acciones
# Déjalo en 0 para deshabilitar los logs en canal
LOG_CHANNEL_ID=0

# ID del canal donde se notifican las nuevas solicitudes a los admins
# Déjalo en 0 para deshabilitar las notificaciones
APPROVAL_CHANNEL_ID=0
